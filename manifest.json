{
  "manifest_version": 3,
  "name": "Claude Usage Widget Lite",
  "version": "1.1.0",
  "description": "Floating widget for your claude.ai usage — session & weekly limits, reset countdown, and live Claude service status.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "src/icon/icon-16.png",
    "32": "src/icon/icon-32.png",
    "48": "src/icon/icon-48.png",
    "128": "src/icon/icon-128.png"
  },
  "action": {
    "default_title": "Toggle Claude Usage Widget Lite",
    "default_icon": {
      "16": "src/icon/icon-16.png",
      "32": "src/icon/icon-32.png",
      "48": "src/icon/icon-48.png",
      "128": "src/icon/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "src/loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content.js",
        "src/ENV.js",
        "src/usage-api.js",
        "src/status-api.js",
        "src/format.js",
        "src/widget.js",
        "src/widget.css.js",
        "src/theme.js",
        "src/button.js",
        "src/inline-button.js"
      ],
      "matches": [
        "https://claude.ai/*"
      ]
    }
  ]
}
