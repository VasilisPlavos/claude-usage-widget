{
  "manifest_version": 3,
  "name": "Claude Usage Widget Lite",
  "version": "1.0.0",
  "description": "Floating picture-in-picture widget showing your claude.ai usage.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Toggle Claude Usage Widget Lite"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "src/loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content.js",
        "src/ENV.js",
        "src/usage-api.js",
        "src/format.js",
        "src/widget.js",
        "src/widget.css.js",
        "src/theme.js",
        "src/button.js",
        "src/inline-button.js"
      ],
      "matches": [
        "https://claude.ai/*"
      ]
    }
  ]
}
